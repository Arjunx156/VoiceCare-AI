# ==========================================
# CommerceMind VoiceCare AI — Environment Variables
# ==========================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore.

# ---------- Bhashini (STT/TTS) ----------
BHASHINI_USER_ID=your_user_id_here
BHASHINI_API_KEY=your_api_key_here
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference

# ---------- Gemini (LLM) ----------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------- PostgreSQL (Neon) ----------
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL_SYNC=postgresql://user:password@host/dbname

# ---------- Redis (Upstash) ----------
REDIS_URL=redis://default:password@host:port

# ---------- NextAuth ----------
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ---------- App Config ----------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CHROMA_PERSIST_DIR=./chroma_data
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- Admin Credentials (Demo) ----------
ADMIN_EMAIL=admin@voicecare.ai
ADMIN_PASSWORD=change_this_in_production
